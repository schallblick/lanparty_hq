# Copy to .env and fill in. Start the server with:
#   node --env-file=.env server.js   (Node 20.6+)

# Steam Web API key — https://steamcommunity.com/dev/apikey
STEAM_KEY=YOUR_STEAM_API_KEY

# SteamID64 of each player, comma-separated — find yours at https://steamid.io
# Profiles must have "Game details" set to Public.
STEAM_IDS=76561198000000001,76561198000000002,76561198000000003

# Hydration reminder interval in minutes (default 30)
WATER_MINS=30

# HTTP port (default 3000)
PORT=3000
